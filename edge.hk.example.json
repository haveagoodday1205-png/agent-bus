{
  "nodeId": "browser-research-node",
  "gatewayUrl": "https://YOUR-CENTRAL-GATEWAY",
  "token": "change-me-to-a-scoped-edge-token",
  "tokenScope": "edge",
  "pollTimeoutMs": 25000,
  "idleDelayMs": 1000,
  "defaultTimeoutMs": 600000,
  "agents": [
    {
      "id": "openclaw-edge",
      "kind": "openclaw",
      "role": "executor",
      "enabled": true,
      "adapter": "command",
      "capabilities": ["shell", "files", "browser", "cron", "skills"],
      "pingUrl": "https://YOUR-MODEL-GATEWAY/v1/models",
      "healthCommand": "openclaw gateway status",
      "runCommand": "OPENCLAW_AGENT_ID=agent-bus ./scripts/openclaw-agent-bus.sh"
    },
    {
      "id": "hermes-edge",
      "kind": "hermes",
      "role": "researcher",
      "enabled": true,
      "adapter": "command",
      "capabilities": ["skills", "memory", "shell", "webhook", "cron"],
      "pingUrl": "https://YOUR-MODEL-GATEWAY/v1/models",
      "healthCommand": "test -x /root/.local/bin/hermes && /root/.local/bin/hermes --help 2>&1 | head -30",
      "runCommand": "/root/.local/bin/hermes chat -q \"$AGENT_MESSAGE\" -Q"
    }
  ]
}
