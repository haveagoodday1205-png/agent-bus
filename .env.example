# Replace AGENT_BUS_TOKEN before `docker compose up`.
# The bundled Compose stack intentionally ships one central service plus the
# `agent-bus-data` volume; it does not require a database container on day one.
AGENT_BUS_TOKEN=replace-with-a-long-random-token
AGENT_BUS_HOST=127.0.0.1
AGENT_BUS_PORT=8788
AGENT_BUS_CONFIG=central.config.json
AGENT_BUS_CENTRAL_RUNTIME=python
AGENT_BUS_DATA_DIR=./data/central

# Compose pins its own host/config/data-dir values and reads the token plus
# optional backend API keys from this file.
# Optional OpenAI-compatible backend keys.
AGENT_BUS_MODEL_API_KEY=
SUB2API_API_KEY=
CLIPROXY_API_KEY=

# Windows local proxy.
AGENT_BUS_UPSTREAM=http://127.0.0.1:8788
AGENT_BUS_WINDOWS_HOST=127.0.0.1
AGENT_BUS_WINDOWS_PORT=8789
