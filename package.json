{
  "name": "agent-bus-cli",
  "version": "0.5.5",
  "description": "Self-hosted remote-assistant CLI for routing AI agents, model gateways, and AI-to-AI rooms across machines.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haveagoodday1205-png/agent-bus.git"
  },
  "bugs": {
    "url": "https://github.com/haveagoodday1205-png/agent-bus/issues"
  },
  "homepage": "https://github.com/haveagoodday1205-png/agent-bus#readme",
  "bin": {
    "agent-bus": "./agent-bus.mjs"
  },
  "keywords": [
    "agent",
    "ai",
    "ai-agents",
    "openai",
    "model-router",
    "ai-to-ai",
    "cli",
    "codex",
    "distributed",
    "remote-assistant",
    "self-hosted"
  ],
  "type": "module",
  "scripts": {
    "cli": "node agent-bus.mjs",
    "start": "node central-gateway.mjs serve",
    "ssh-prototype": "node server.mjs serve",
    "central": "node central-gateway.mjs serve",
    "edge": "node edge-node.mjs connect",
    "edge:agents": "node edge-node.mjs agents",
    "edge:health": "node edge-node.mjs health",
    "mock:model": "node mock-openai-backend.mjs",
    "windows:proxy": "node windows-openai-proxy.mjs",
    "smoke": "node smoke-test.mjs",
    "smoke:offline": "node scripts/offline-smoke.mjs",
    "compat:check": "node scripts/compatibility-smoke.mjs",
    "smoke:room-stale": "node scripts/room-autonomy-stale-smoke.mjs",
    "demo:local": "node scripts/demo-local.mjs",
    "demo:remote-assistant": "node scripts/demo-local.mjs",
    "bundle": "node scripts/make-portable-release.mjs",
    "run": "node server.mjs run",
    "route": "node server.mjs route",
    "health": "node server.mjs health",
    "agents": "node server.mjs agents",
    "pack:check": "node scripts/verify-package.mjs",
    "portable:check": "node scripts/verify-portable-release.mjs",
    "portable:check:zip": "node scripts/verify-portable-release.mjs --zip",
    "release:check": "node scripts/release-check.mjs",
    "demo:room": "node scripts/demo-room.mjs",
    "release:notes": "node scripts/release-notes.mjs",
    "release:preflight": "node scripts/release-preflight.mjs",
    "smoke:npm-install": "node scripts/npm-install-smoke.mjs",
    "protocol:check": "node scripts/verify-protocol-v1.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "agent-bus.mjs",
    "central-gateway.mjs",
    "central_gateway.py",
    "edge-node.mjs",
    "edge_node.py",
    "server.mjs",
    "smoke-test.mjs",
    "mock-openai-backend.mjs",
    "windows-openai-proxy.mjs",
    "start-windows-openai-proxy.ps1",
    "central.config.example.json",
    "edge.config.example.json",
    "edge.120.example.json",
    "edge.178.example.json",
    "edge.hk.example.json",
    "config.example.json",
    ".env.example",
    "Dockerfile",
    "compose.yaml",
    "console/**",
    "docs/**",
    "examples/**",
    "scripts/**",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ]
}
