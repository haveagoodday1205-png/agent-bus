# Replace AGENT_BUS_TOKEN before `docker compose up`.
# The bundled Compose stack intentionally ships one central service plus the
# `agent-bus-data` volume; it does not require a database container on day one.
AGENT_BUS_TOKEN=replace-with-a-long-random-token
AGENT_BUS_HOST=127.0.0.1
AGENT_BUS_PORT=8788
AGENT_BUS_CONFIG=central.config.json
AGENT_BUS_CENTRAL_RUNTIME=python
AGENT_BUS_DATA_DIR=./data/central

# Compose pins its own host/config/data-dir values and reads the token plus
# optional backend API keys from this file.
# Optional OpenAI-compatible backend keys.
AGENT_BUS_MODEL_API_KEY=
SUB2API_API_KEY=
CLIPROXY_API_KEY=

# Optional Central Telegram plugin.
AGENT_BUS_TELEGRAM_ENABLED=false
AGENT_BUS_TELEGRAM_BOT_TOKEN=
AGENT_BUS_TELEGRAM_CHAT_ID=
AGENT_BUS_TELEGRAM_CONTROL_ENABLED=false
AGENT_BUS_TELEGRAM_WEBHOOK_SECRET=
AGENT_BUS_TELEGRAM_SET_COMMANDS=false
AGENT_BUS_TELEGRAM_CONVERSATION_ENABLED=false
AGENT_BUS_TELEGRAM_CONVERSATION_AGENT=
AGENT_BUS_TELEGRAM_CONVERSATION_AGENTS=
AGENT_BUS_TELEGRAM_PROMPT_MAX_BYTES=20000
AGENT_BUS_TELEGRAM_PROMPT_MESSAGE_COUNT=8
AGENT_BUS_TELEGRAM_PROMPT_MESSAGE_CHARS=1800
AGENT_BUS_TELEGRAM_PROMPT_LATEST_CHARS=4000

# Optional local extractive memory cache for older room context.
AGENT_BUS_ROOM_MEMORY_CACHE_ENABLED=true
AGENT_BUS_ROOM_MEMORY_SNIPPETS=10
AGENT_BUS_ROOM_MEMORY_PROMPT_SNIPPETS=6
AGENT_BUS_ROOM_MEMORY_SNIPPET_CHARS=260
AGENT_BUS_ROOM_MEMORY_KEYWORDS=32
AGENT_BUS_ROOM_MEMORY_ENTITIES=20
AGENT_BUS_ROOM_MEMORY_INDEX_ENTRIES=16
AGENT_BUS_ROOM_MEMORY_PROMPT_INDEX_ENTRIES=10
AGENT_BUS_ROOM_MEMORY_INDEX_TOPICS=5

# Windows local proxy.
AGENT_BUS_UPSTREAM=http://127.0.0.1:8788
AGENT_BUS_WINDOWS_HOST=127.0.0.1
AGENT_BUS_WINDOWS_PORT=8789
