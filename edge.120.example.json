{
  "nodeId": "code-node",
  "gatewayUrl": "https://YOUR-CENTRAL-GATEWAY",
  "token": "change-me",
  "pollTimeoutMs": 25000,
  "idleDelayMs": 1000,
  "defaultTimeoutMs": 600000,
  "agents": [
    {
      "id": "codex-edge",
      "kind": "codex",
      "role": "coder",
      "enabled": true,
      "adapter": "command",
      "capabilities": ["code", "review", "shell", "files"],
      "pingUrl": "https://api.openai.com/v1/models",
      "healthCommand": "codex --help | head -40",
      "runCommand": "codex exec --color never --dangerously-bypass-approvals-and-sandbox \"$AGENT_MESSAGE\" < /dev/null"
    }
  ]
}
