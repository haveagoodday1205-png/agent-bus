{
  "nodeId": "local-dev",
  "gatewayUrl": "http://127.0.0.1:8788",
  "token": "change-me-to-a-scoped-edge-token",
  "tokenScope": "edge",
  "pollTimeoutMs": 25000,
  "pollRequestGraceMs": 5000,
  "requestTimeoutMs": 60000,
  "idleDelayMs": 1000,
  "defaultTimeoutMs": 600000,
  "dataDir": "./data/edge",
  "completionOutboxDir": "./data/edge/edge-completions",
  "agents": [
    {
      "id": "local-echo",
      "kind": "echo",
      "role": "executor",
      "enabled": true,
      "adapter": "echo",
      "capabilities": ["shell", "files"],
      "permission_profile": "local-demo",
      "allowed_wake_targets": ["local-echo"]
    }
  ]
}
